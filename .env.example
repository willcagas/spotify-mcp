# Required: Your Spotify app's Client ID
SPOTIFY_CLIENT_ID=your_client_id_here

# Optional: Client secret is NOT required for PKCE auth flow
# Only set this if you want to use the Authorization Code flow with client secret
# SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Optional: Override the default redirect URI (default: http://127.0.0.1:{random_port}/callback)
# Must use 127.0.0.1, NOT localhost (banned by Spotify since Apr 2025)
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
